{
	"info": {
		"name": "API_Task",
		"description": "E2E API Test flow for restful-api.dev covering POST, GET, and DELETE methods with dynamic variables.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Create Object",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"var jsonData = pm.response.json();",
							"",
							"pm.test(\"Object is created and has ID\", function () {",
							"    pm.expect(jsonData.id).to.exist;",
							"});",
							"",
							"pm.test(\"Name matches the payload\", function () {",
							"    pm.expect(jsonData.name).to.eql(\"Apple MacBook Pro 16 QA Edition\");",
							"});",
							"",
							"pm.collectionVariables.set(\"objectId\", jsonData.id);",
							"console.log(\"Created Object ID: \" + jsonData.id);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n   \"name\": \"Apple MacBook Pro 16 QA Edition\",\n   \"data\": {\n      \"year\": 2026,\n      \"price\": 2050.99,\n      \"CPU model\": \"M4 Max\"\n   }\n}"
				},
				"url": {
					"raw": "{{baseURL}}",
					"host": [
						"{{baseURL}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "2. Get Created Object",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"var jsonData = pm.response.json();",
							"",
							"pm.test(\"Fetched object ID matches the created one\", function () {",
							"    pm.expect(jsonData.id).to.eql(pm.collectionVariables.get(\"objectId\"));",
							"});",
							"",
							"pm.test(\"Fetched name is correct\", function () {",
							"    pm.expect(jsonData.name).to.eql(\"Apple MacBook Pro 16 QA Edition\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseURL}}/{{objectId}}",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"{{objectId}}"
					]
				}
			},
			"response": []
		},
		{
			"name": "3. Delete Object",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"var jsonData = pm.response.json();",
							"var deletedId = pm.collectionVariables.get(\"objectId\");",
							"",
							"pm.test(\"Success message contains correct ID\", function () {",
							"    pm.expect(jsonData.message).to.include(\"Object with id = \" + deletedId + \" has been deleted\");",
							"});",
							"",
							"pm.collectionVariables.unset(\"objectId\");"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseURL}}/{{objectId}}",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"{{objectId}}"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseURL",
			"value": "https://api.restful-api.dev/objects",
			"type": "string"
		},
		{
			"key": "objectId",
			"value": ""
		}
	]
}